    <worksheet name='Product Decline'>
      <table>
        <view>
          <datasources>
            <datasource caption='sales_data+' name='federated.1gcl2z60hla4j11ann2p70ntqo5s' />
          </datasources>
          <datasource-dependencies datasource='federated.1gcl2z60hla4j11ann2p70ntqo5s'>
            <column caption='Monthly Decline' datatype='integer' name='[Calculation_6245583005564955]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([sales]) &lt; LOOKUP(SUM([sales]), -1) THEN 1 ELSE 0 END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Decline Flag' datatype='string' name='[Calculation_6245583005659164]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF WINDOW_SUM([Calculation_6245583005564955], -2, 0) = 3 THEN &quot;⚠ Declining 3 months&quot; ELSE &quot;OK&quot; END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Latest Month Only ' datatype='boolean' name='[Calculation_6245583007350816]' role='measure' type='nominal'>
              <calculation class='tableau' formula='LAST() = 0'>
                <table-calc ordering-type='Rows' />
