              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[order_date]) = { MAX(DATETRUNC(&apos;month&apos;,[order_date])) }' />
            </column>
            <column caption='Last Month Flag' datatype='boolean' name='[Calculation_6245582957121543]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[order_date]) = DATEADD(&apos;month&apos;, -1, { MAX(DATETRUNC(&apos;month&apos;,[order_date])) })' />
            </column>
            <column caption='Units this month' datatype='integer' name='[Calculation_6245582958166027]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_6245582956871686] THEN [quantity] END)' />
            </column>
            <column caption='Units last month' datatype='integer' name='[Calculation_6245582958297100]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_6245582957121543] THEN [quantity] END)' />
            </column>
            <column caption='Units MoM %    ' datatype='real' default-format='p0.00%' name='[Calculation_6245582958473229]' role='measure' type='quantitative'>
