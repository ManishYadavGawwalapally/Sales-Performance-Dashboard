      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='sales_data+' name='federated.1gcl2z60hla4j11ann2p70ntqo5s' />
          </datasources>
          <datasource-dependencies datasource='federated.1gcl2z60hla4j11ann2p70ntqo5s'>
            <column caption='This Month Flag' datatype='boolean' name='[Calculation_6245582956871686]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[order_date]) = { MAX(DATETRUNC(&apos;month&apos;,[order_date])) }' />
            </column>
            <column caption='Last Month Flag' datatype='boolean' name='[Calculation_6245582957121543]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[order_date]) = DATEADD(&apos;month&apos;, -1, { MAX(DATETRUNC(&apos;month&apos;,[order_date])) })' />
            </column>
            <column caption='Revenue This Month' datatype='real' name='[Calculation_6245582957764616]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_6245582956871686] THEN [sales] END)' />
            </column>
            <column caption='Revenue Last Month' datatype='real' name='[Calculation_6245582957879305]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_6245582957121543] THEN [sales] END)' />
            </column>
            <column caption='Revenue MoM %' datatype='real' default-format='p0.00%' name='[Calculation_6245582958010378]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_6245582957764616] - [Calculation_6245582957879305]) / [Calculation_6245582957879305]' />
            </column>
            <column caption='Return Rate This Month' datatype='real' name='[Calculation_6245582959841297]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_6245582956871686] THEN [is_returned] END) / COUNTD(IF [Calculation_6245582956871686] THEN [order_id] END)' />
            </column>
            <column caption='Return Rate Last Month' datatype='real' name='[Calculation_6245582960066578]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_6245582957121543] THEN [is_returned] END) / COUNTD(IF [Calculation_6245582957121543] THEN [order_id] END)' />
            </column>
            <column caption='Return Rate MoM %' datatype='real' default-format='p0.00%' name='[Calculation_6245582960328723]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_6245582959841297] - [Calculation_6245582960066578]) / [Calculation_6245582960066578]' />
            </column>
            <column caption='Revenue Direction' datatype='string' name='[Calculation_6245582964359188]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_6245582958010378] &gt;= 0 THEN &apos;Up&apos; ELSE &apos;Down&apos; END' />
            </column>
            <column caption='Category Of Goods' datatype='string' name='[category_of_goods]' role='dimension' type='nominal' />
            <column caption='Is Returned' datatype='integer' name='[is_returned]' role='measure' type='quantitative' />
            <column-instance column='[category_of_goods]' derivation='None' name='[none:category_of_goods:nk]' pivot='key' type='nominal' />
            <column-instance column='[region]' derivation='None' name='[none:region:nk]' pivot='key' type='nominal' />
            <column caption='Order Date' datatype='date' name='[order_date]' role='dimension' type='ordinal' />
            <column caption='Order Id' datatype='string' name='[order_id]' role='dimension' type='nominal' />
            <column caption='Region' datatype='string' name='[region]' role='dimension' type='nominal' />
            <column caption='Sales' datatype='real' name='[sales]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_6245582959841297]' derivation='User' name='[usr:Calculation_6245582959841297:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_6245582960328723]' derivation='User' name='[usr:Calculation_6245582960328723:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_6245582964359188]' derivation='User' name='[usr:Calculation_6245582964359188:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
